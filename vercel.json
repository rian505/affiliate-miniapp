{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app.py" },
    { "src": "/generate-prompt", "dest": "app.py" },
    { "src": "/sheets", "dest": "app.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
